# Server Configuration
PORT=3000

# Frontend URL (for CORS)
# In production, set this to your actual frontend domain
FRONTEND_URL=http://localhost:5500

# Twilio SMS notifications for new leads
# Sign up at https://www.twilio.com, grab Account SID + Auth Token from the Console,
# and provision a phone number (Phone Numbers > Manage > Buy a Number) for FROM.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# Destination phone to receive lead alerts (E.164 format: +1XXXXXXXXXX).
# Defaults to +13147741700 if unset.
NOTIFY_PHONE=+13147741700
